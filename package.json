{
  "name": "mcp-context-provider",
  "version": "2.0.0-alpha.2",
  "description": "MCP context & instinct engine — learned rules from sessions with confidence scoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-cp": "dist/cli/index.js",
    "mcp-context-provider": "dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "start:http": "node dist/server/index.js --http",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/doobidoo/MCP-Context-Provider.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "context",
    "instinct",
    "learning",
    "claude-code"
  ],
  "author": "doobidoo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
