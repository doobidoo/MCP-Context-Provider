{
  "name": "mcp-context-provider",
  "description": "MCP context & instinct engine — learned rules from sessions with confidence scoring",
  "owner": {
    "name": "doobidoo",
    "email": "henry.krupp@gmail.com"
  },
  "homepage": "https://github.com/doobidoo/MCP-Context-Provider",
  "plugins": [
    {
      "name": "context-provider",
      "source": ".",
      "description": "MCP server that provides tool-aware context injection and learned instincts with confidence scoring. Includes 6 MCP tools: get_tool_context, get_syntax_rules, list_available_contexts, apply_auto_corrections, build_injection, and list_instincts.",
      "version": "2.0.0-alpha.4",
      "author": {
        "name": "doobidoo"
      },
      "homepage": "https://github.com/doobidoo/MCP-Context-Provider",
      "repository": "https://github.com/doobidoo/MCP-Context-Provider",
      "license": "MIT",
      "keywords": [
        "mcp",
        "context",
        "instinct",
        "learning",
        "claude-code",
        "confidence-scoring",
        "tool-context"
      ],
      "category": "code-intelligence",
      "mcpServers": {
        "context-provider": {
          "command": "node",
          "args": ["${CLAUDE_PLUGIN_ROOT}/dist/server/index.js"],
          "env": {
            "CONTEXTS_PATH": "${CLAUDE_PLUGIN_ROOT}/contexts",
            "INSTINCTS_PATH": "${CLAUDE_PLUGIN_ROOT}/instincts"
          }
        }
      }
    }
  ]
}
