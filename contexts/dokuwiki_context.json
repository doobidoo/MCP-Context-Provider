{
  "tool_category": "dokuwiki",
  "description": "DokuWiki-specific context rules and syntax preferences",
  "auto_convert": true,
  "syntax_rules": {
    "headers": {
      "format": "======",
      "levels": {
        "1": "====== {} ======",
        "2": "===== {} =====",
        "3": "==== {} ====",
        "4": "=== {} ===",
        "5": "== {} =="
      },
      "avoid": [
        "#",
        "##",
        "###",
        "####",
        "#####",
        "######"
      ]
    },
    "code_blocks": {
      "format": "<code {}>\n{}\n</code>",
      "avoid": [
        "```",
        "~~~"
      ],
      "language_tags": {
        "description": "Always specify language in code blocks for syntax highlighting",
        "examples": [
          "<code sql>",
          "<code powershell>",
          "<code bash>",
          "<code python>",
          "<code terraform>",
          "<code abap>"
        ]
      },
      "mandatory_tagging": {
        "description": "EVERY code block MUST be followed by a corresponding tag for automatic listing on intern:tott:start#scripts",
        "format": "</code>{{tag>tagname}}",
        "language_to_tag_mapping": {
          "sql": "{{tag>\"SQL Statement\"}}",
          "powershell": "{{tag>powershell}}",
          "python": "{{tag>python}}",
          "bash": "{{tag>bash}}",
          "terraform": "{{tag>terraform}}",
          "java": "{{tag>java}}",
          "javascript": "{{tag>javascript}}",
          "csharp": "{{tag>csharp}}",
          "xml": "{{tag>xml}}",
          "json": "{{tag>json}}",
          "yaml": "{{tag>yaml}}",
          "mermaid": "{{tag>diagram}}",
          "plantuml": "{{tag>PlantUML}}",
          "abap": "{{tag>abap}}",
          "kusto": "{{tag>kusto}}",
          "cli": "{{tag>bash}}"
        },
        "example": "<code sql>\nSELECT * FROM users;\n</code>{{tag>\"SQL Statement\"}}"
      }
    },
    "alerts": {
      "warning": "<WRAP center round alert>{}</WRAP>",
      "tip": "<WRAP center round tip>{}</WRAP>",
      "important": "<WRAP center round important>{}</WRAP>",
      "info": "<WRAP center round info>{}</WRAP>",
      "box": "<WRAP center round box>{}</WRAP>",
      "avoid": [
        "<note>",
        "</note>",
        "<note warning>",
        "<note tip>",
        "<note important>"
      ],
      "description": "Use WRAP plugin syntax for callouts/notices"
    },
    "links": {
      "format": "[[{}|{}]]",
      "avoid": [
        "[{}]({})",
        "<a href"
      ]
    },
    "inline_code": {
      "format": "''{}''",
      "avoid": [
        "`{}`"
      ],
      "limitations": {
        "description": "Inline monospace ''..'' has markup conflicts with certain characters",
        "problematic_content": [
          "Curly braces {} - conflicts with DokuWiki syntax",
          "Single quotes ' - can break the ''..'' delimiter",
          "Complex shell commands with mixed quotes",
          "JSON snippets or objects"
        ],
        "solution": "Use <code> blocks instead of inline ''..'' for complex content",
        "examples": {
          "bad": "''curl -d '{}'%%''%%'' (markup conflict with {})",
          "good": "<code bash>\ncurl -X POST url -d '{}'\n</code>"
        },
        "rule": "If content contains {}, complex quotes, or is longer than ~60 chars, use <code> block"
      }
    },
    "tags": {
      "format": "{{tag>{}}}",
      "location": "end_of_page AND after each code block",
      "separator": " ",
      "description": "Tags for categorization. Use quotes for multi-word tags: {{tag>\"SQL Statement\"}}",
      "avoid": [
        "**Tags:**",
        "Tags:",
        "#tag"
      ]
    },
    "literal_text": {
      "format": "%%{}%%",
      "description": "Renders text literally without wiki formatting. MUST always be closed - an unclosed %% breaks the entire page rendering.",
      "rules": [
        "Every opening %% MUST have a matching closing %%",
        "Never use %% for decorative purposes - only when literal rendering is actually needed",
        "Prefer ''..'' for inline code or <code> blocks for longer content",
        "If the text does not contain DokuWiki special characters, do NOT use %% at all"
      ],
      "examples": {
        "correct": "Use %%$env:PATH%% to access the variable",
        "correct2": "The pattern is %%{kunde}-data%%",
        "wrong": "Use %% without closing - breaks entire page from this point onward"
      }
    }
  },
  "preferences": {
    "date_format": "manual",
    "avoid_macros": [
      "{{date}}",
      "{{time}}",
      "{{user}}"
    ],
    "manual_date_format": "YYYY-MM-DD",
    "url_pattern": {
      "base_url": "https://<INTERNAL_IP>/wiki/doku.php/",
      "format": "https://<INTERNAL_IP>/wiki/doku.php/{namespace}:{page}",
      "separator": ":",
      "description": "DokuWiki URLs use colons (:) as namespace separators, not slashes. Base URL is internal IP, NOT public domain.",
      "example": "https://<INTERNAL_IP>/wiki/doku.php/method:cloud:troubleshooting:azure-storage-sftp",
      "avoid": [
        "<PUBLIC_WIKI_DOMAIN>",
        "namespace/page (use namespace:page instead)"
      ]
    }
  },
  "auto_corrections": {
    "headers": {
      "pattern": "^(#{1,6})\\s*(.+)$",
      "replacement": "====== $2 ======"
    },
    "code_blocks": {
      "pattern": "^```(\\w+)",
      "replacement": "<code $1>"
    },
    "links": {
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "replacement": "[[$2|$1]]"
    },
    "note_to_wrap_warning": {
      "pattern": "<note\\s*warning>",
      "replacement": "<WRAP center round alert>"
    },
    "note_to_wrap_tip": {
      "pattern": "<note\\s*tip>",
      "replacement": "<WRAP center round tip>"
    },
    "note_to_wrap_important": {
      "pattern": "<note\\s*important>",
      "replacement": "<WRAP center round important>"
    },
    "note_to_wrap_info": {
      "pattern": "<note>",
      "replacement": "<WRAP center round info>"
    },
    "note_close_to_wrap": {
      "pattern": "</note>",
      "replacement": "</WRAP>"
    },
    "date_macro": {
      "pattern": "\\{\\{date[^}]*\\}\\}",
      "replacement": "{{CURRENT_DATE}}"
    },
    "tags_markdown": {
      "pattern": "(?:^|\\n)(?:\\*\\*)?[Tt]ags?:?(?:\\*\\*)?\\s*(.+)$",
      "replacement": "{{tag>$1}}"
    }
  },
  "metadata": {
    "version": "1.0.0",
    "last_updated": "2026-01-29T12:00:00.000000",
    "applies_to_tools": [
      "dokuwiki:core_savePage",
      "dokuwiki:core_appendPage",
      "dokuwiki:*"
    ]
  },
  "auto_store_triggers": {
    "wiki_syntax": {
      "tags": [
        "dokuwiki",
        "wiki",
        "documentation"
      ],
      "action": "store_with_metadata",
      "patterns": [
        "======",
        "=====",
        "====",
        "<code",
        "</code>",
        "<note",
        "</note>",
        "[[",
        "]]"
      ],
      "confidence_threshold": 0.8
    },
    "documentation_creation": {
      "tags": [
        "dokuwiki",
        "documentation",
        "knowledge-base"
      ],
      "action": "store_with_metadata",
      "patterns": [
        "create wiki page",
        "document this",
        "add to wiki",
        "wiki entry for"
      ],
      "confidence_threshold": 0.7
    }
  },
  "auto_retrieve_triggers": {
    "wiki_help": {
      "action": "search_and_suggest",
      "patterns": [
        "dokuwiki syntax",
        "wiki formatting",
        "how to format wiki",
        "wiki markup"
      ],
      "search_tags": [
        "dokuwiki",
        "syntax",
        "formatting"
      ],
      "confidence_threshold": 0.8
    },
    "documentation_search": {
      "action": "search_and_suggest",
      "patterns": [
        "find in wiki",
        "wiki page about",
        "documented in wiki",
        "wiki entry for"
      ],
      "search_tags": [
        "dokuwiki",
        "documentation"
      ],
      "confidence_threshold": 0.7
    }
  },
  "session_initialization": {
    "enabled": true,
    "actions": {
      "on_startup": [
        {
          "action": "search_memory",
          "store_as": "recent_wiki",
          "parameters": {
            "tags": [
              "dokuwiki"
            ],
            "n_results": 5
          }
        },
        {
          "action": "notify",
          "message": "DokuWiki context loaded. Found {recent_wiki.count} wiki-related items."
        }
      ]
    }
  },
  "editing_best_practices": {
    "description": "Best practices for editing existing DokuWiki pages",
    "rules": {
      "incremental_changes": {
        "description": "NEVER rewrite entire pages at once. Make small, targeted changes only.",
        "reason": "Large rewrites risk losing content, breaking formatting, and removing intentional structure.",
        "approach": [
          "Make ONE type of change at a time (e.g., only fix links, or only add tags)",
          "Preserve existing structure and formatting",
          "Test changes incrementally",
          "Ask before making major structural changes"
        ]
      },
      "preserve_existing": {
        "description": "Respect the existing page structure and style",
        "rules": [
          "Keep the original heading hierarchy",
          "Don't change formatting conventions used on the page",
          "Don't remove content unless explicitly asked",
          "Don't 'clean up' sections that weren't mentioned"
        ]
      },
      "safe_changes": {
        "description": "Changes that are generally safe to make",
        "examples": [
          "Adding tags to code blocks",
          "Fixing broken links",
          "Adding new content at the end",
          "Correcting typos"
        ]
      },
      "dangerous_changes": {
        "description": "Changes that require explicit user approval",
        "examples": [
          "Restructuring sections",
          "Changing heading levels",
          "Removing duplicate entries",
          "Converting link syntax across entire page",
          "Reformatting lists"
        ]
      }
    }
  }
}