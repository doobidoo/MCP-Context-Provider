      ]
    },
    "banned_patterns": {
      "in_a_world_where": {
        "detect": "In a world where [scary/overwhelming change], [virtue/edge] becomes [currency/advantage]",
        "rewrite_options": [
          "Today, [specific change]. So [practical implication for reader].",
          "Because [concrete change], do [specific action] to get [specific result]."
        ]
      },
      "most_people_vs_few": {
        "detect": "Most people [lazy thing]. The few who win [disciplined thing].",
        "rewrite_options": [
          "Among [group], [specific stat/observation]. What works: [one tactic].",
          "Personal stance: I do [specific practice] to avoid [specific downside]."
        ]
      },
      "stop_start_switch": {
        "detect": "Stop [old habit]. Start [new habit].",
        "rewrite_options": [
          "If you're doing [X], switch to [Y] when [condition], because [reason].",
          "Replace [X] with [Y]: [1-3 concrete steps]."
        ]
      },
      "journey_narrative": {
        "detect": "The journey from [A] to [B] is/was [superlative]",
        "rewrite_options": [
          "Moving from [A] to [B] took [time/effort]. Here's what changed: [specifics]."
        ]
      },
      "embrace_the_future": {
        "detect": "Embrace [trend/technology] to stay ahead/competitive",
        "rewrite_options": [
          "Use [specific tool/method] for [specific benefit]. Example: [concrete case]."
        ]
      }
    },
    "replacement_guidance": {
      "leverage": [
        "use",
        "apply",
        "rely on"
      ],
      "utilize": [
        "use"
      ],
      "optimize": [
        "improve",
        "speed up",
        "fix"
      ],
      "streamline": [
        "simplify",
        "cut steps from",
        "shorten"
      ],
      "empower": [
        "let",
        "help",
        "give [person] control over"
      ],
      "transformative": [
        "useful",
        "changes how we [verb]"
      ],
      "seamless": [
        "smooth",
        "without [specific friction]"
      ],
      "robust": [
        "stable",
        "handles [specific edge case]"
      ],
      "scalable": [
        "grows with [specific metric]"
      ],
      "innovative": [
        "new",
        "different because [reason]"
      ],
      "cutting-edge": [
        "recent",
        "uses [specific tech]"
      ],
      "game-changer": [
        "matters because [specific reason]"
      ],
      "paradigm": [
        "approach",
        "method",
        "way of thinking"
      ],
      "landscape": [
        "market",
        "field",
        "situation"
      ],
      "ecosystem": [
        "system",
        "tools",
        "environment"
      ],
      "synergy": [
        "combination",
        "overlap",
        "shared benefit"
      ],
      "holistic": [
        "complete",
        "full",
        "end-to-end"
      ],
      "dynamic": [
        "changing",
        "active",
        "responsive to [trigger]"
      ]
    }
  },
  "preferences": {
    "preserve_content": true,
    "preserve_pov": true,
    "preserve_tense": true,
    "preserve_structure": true,
    "output_only_edited_text": true,
    "no_explanatory_notes": true
  },
  "auto_corrections": {
    "delve into": {"pattern": "delve into", "replacement": "look at"},
    "delve deeper": {"pattern": "delve deeper", "replacement": "dig into"},
    "it's important to note": {"pattern": "it's important to note", "replacement": "[delete or state the fact directly]"},
    "it's worth noting": {"pattern": "it's worth noting", "replacement": "[delete or state the fact directly]"},
    "at the end of the day": {"pattern": "at the end of the day", "replacement": "[delete]"},
    "in today's fast-paced world": {"pattern": "in today's fast-paced world", "replacement": "[delete or be specific about what changed]"},
    "navigate the complexities": {"pattern": "navigate the complexities", "replacement": "handle"},
    "unlock the potential": {"pattern": "unlock the potential", "replacement": "get more from"},
    "harness the power": {"pattern": "harness the power", "replacement": "use"},
    "in this article": {"pattern": "in this article", "replacement": "[delete - reader knows where they are]"},
    "without further ado": {"pattern": "without further ado", "replacement": "[delete]"}
  },
  "auto_store_triggers": {
    "writing_edits": {
      "tags": [
        "writing",
        "anti-ai",
        "rewrite"
      ],
      "action": "store_with_metadata",
      "patterns": [
        "rewrite",
        "rephrase",
        "make it sound human",
        "remove buzzwords",
        "anti-ai"
      ],
      "confidence_threshold": 0.7
    }
  },
  "auto_retrieve_triggers": {
    "writing_help": {
      "action": "search_and_suggest",
      "patterns": [
        "sounds too AI",
        "rewrite this",
        "make it natural",
        "too corporate",
        "buzzword"
      ],
      "search_tags": [
        "writing",
        "anti-ai",
        "rewrite"
      ],
      "confidence_threshold": 0.7
    }
  },
  "session_initialization": {
    "enabled": true,
    "actions": {
      "on_startup": [
        {
          "action": "notify",
          "message": "Anti-AI voice context loaded. Will detect and replace AI-sounding language."
        }
      ]
    }
  }
