        "{tool_name}"
      ],
      "priority": "high"
    },
    "learning_moments": {
      "patterns": [
        "I learned that",
        "I discovered",
        "It turns out",
        "The issue was",
        "I found out",
        "The problem was",
        "Ich habe gelernt",
