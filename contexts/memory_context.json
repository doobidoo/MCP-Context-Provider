    "project_context": {
      "patterns": [
        "Working on project",
        "The project",
        "In the {project} project",
        "For {company}",
        "Arbeite an",
        "Das Projekt",
        "Im Projekt",
        "Für den Kunden",
        "Bei DMI",
        "Beim Kunden",
        "Projekt:",
        "bei Mercedes",
        "bei Helvetia",
        "bei Bosch",
