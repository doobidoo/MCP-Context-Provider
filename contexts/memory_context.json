      ],
      "action": "store_memory",
      "tags": [
        "project",
        "{project_name}"
      ],
      "priority": "medium"
    }
  },
  "auto_retrieve_triggers": {
    "problem_solving": {
      "tags": [
        "solution",
        "{topic}"
      ],
      "action": "search_by_tag",
      "patterns": [
        "How did I fix",
        "What was the solution for",
        "Last time this happened",
        "Previous fix for",
        "How did we solve",
        "Wie habe ich das behoben",
        "Was war die Lösung für",
        "Letztes Mal",
        "Wie haben wir das gelöst",
        "Was war der Fix für",
        "hatten wir das nicht schon",
        "hatten wir das mal"
      ]
    },
    "temporal_queries": {
      "action": "recall_memory",
      "patterns": [
        "What did I",
        "When did I",
        "Last week",
        "Recently",
        "Yesterday",
        "This morning",
        "Earlier today",
        "Was habe ich",
        "Wann habe ich",
        "Letzte Woche",
        "Kürzlich",
        "Gestern",
        "Heute Morgen",
        "Vorhin",
        "Zuletzt"
      ],
      "extract_timeframe": true
    },
    "reference_patterns": {
      "action": "retrieve_memory",
      "patterns": [
        "As we discussed",
        "Like before",
        "Remember when",
        "That thing about",
        "You mentioned",
        "We talked about",
        "Wie besprochen",
        "Wie vorhin",
        "Erinnerst du dich",
        "Das Thema mit",
        "Du hast erwähnt",
        "Wir haben darüber geredet",
        "weißt du noch",
        "hatten wir da nicht was"
      ],
      "use_context": true
    },
    "continuation_patterns": {
      "action": "retrieve_memory",
      "patterns": [
        "Continue with",
        "Where were we",
        "Back to",
        "Resume",
        "Pick up where",
        "Let's get back to",
        "Weiter mit",
        "Wo waren wir",
        "Zurück zu",
        "Fortfahren",
        "Weitermachen mit",
        "Nochmal zu"
      ],
      "additional_tags": [
        "in-progress"
      ]
    }
  },
  "smart_tagging": {
    "auto_detect_projects": true,
    "auto_detect_tools": true,
    "temporal_tags": {
      "add_day_of_week": true,
      "add_month": true,
      "add_year": true
    },
    "context_tags": {
      "detect_from_conversation": true,
      "maintain_context_stack": true,
      "max_context_depth": 3
    },
    "tool_detection": {
      "patterns": {
        "terraform": [
          "terraform",
          "tf",
          "hcl"
        ],
        "docker": [
          "docker",
          "dockerfile",
          "container"
        ],
        "kubernetes": [
          "k8s",
          "kubernetes",
          "kubectl"
        ],
        "azure": [
          "azure",
          "az",
          "arm"
        ],
        "aws": [
          "aws",
          "amazon",
          "s3",
          "ec2"
        ],
        "git": [
          "git",
          "github",
          "commit",
          "branch"
        ],
        "python": [
          "python",
          "pip",
          "venv"
        ],
        "javascript": [
          "javascript",
          "js",
          "node",
          "npm"
        ]
      }
    }
  },
  "memory_management": {
    "retention_policy": {
      "default_retention_days": 90,
      "tag_based_retention": {
        "decision": 365,
        "solution": 180,
        "preference": 365,
        "todo": 30,
        "temporary": 7
      }
    },
    "deduplication": {
      "enabled": true,
      "similarity_threshold": 0.95
    },
    "chunking": {
      "max_memory_size": 2000,
      "chunk_overlap": 200
    }
  },
  "context_awareness": {
    "maintain_working_context": true,
    "context_switch_detection": true,
    "suggest_relevant_memories": true,
    "proactive_retrieval": {
      "enabled": true,
      "confidence_threshold": 0.7
    }
  },
  "metadata": {
    "version": "1.2.0",
    "last_updated": "2026-03-09T15:03:43.100254",
    "applies_to_tools": [
      "memory",
